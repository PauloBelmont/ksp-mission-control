# kRPC address and ports (when KSP runs on the host machine)
KRPC_ADDRESS=host.docker.internal
KRPC_RPC_PORT=5000
KRPC_STREAM_PORT=5001

# Internal API URL (used by Streamlit)
API_URL=http://api:8000/telemetry

# How often to poll telemetry when connected (seconds)
POLL_INTERVAL=1.0

# How often to retry connection when kRPC is unavailable (seconds)
RETRY_INTERVAL=5.0
